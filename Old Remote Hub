local function MakeDraggable(guiObject)
    local dragging, dragInput, dragStart, startPos
    local function update(input)
        local delta = input.Position - dragStart
        guiObject.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
    guiObject.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startPos = guiObject.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    guiObject.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then update(input) end
    end)
end

local function createOnScreenButton(remote, inputId, displayName)
    local guiName = "CustomRemoteButtonsGui"
    local gui = CoreGui:FindFirstChild(guiName) or Instance.new("ScreenGui", CoreGui)
    gui.Name = guiName

    local randomId = math.random(1, 100000)
    local btn = Instance.new("TextButton")
    btn.Name = remote.Name .. "_" .. randomId
    btn.Text = "  " .. displayName .. "  "
    btn.Size = UDim2.new(0, 0, 0, 25)
    btn.AutomaticSize = Enum.AutomaticSize.X
    btn.Position = UDim2.new(0, math.random(50, 250), 0, math.random(50, 250))
    btn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.SourceSansBold
    btn.TextSize = 14
    
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    btn.Parent = gui
    MakeDraggable(btn)
    
    btn.MouseButton1Click:Connect(function()
        local amount = tonumber(Options[inputId] and Options[inputId].Value or "1") or 1
        for i = 1, amount do remote:FireServer() end
    end)
end

