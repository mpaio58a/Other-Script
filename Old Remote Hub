MiscGroupbox:AddInput("AimbotTarget", {
    Default = "", Numeric = false, Finished = false, Text = "Aimbot Target", Placeholder = "Name / ran",
    Callback = function(Value)
        if Value == "" then targetPlayer = nil return end
        local name = string.lower(string.match(Value, "^%s*(.-)%s*$"))
        if name == "ran" or name == "random" then
            local plys = {}
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then table.insert(plys, p) end
            end
            if #plys > 0 then targetPlayer = plys[math.random(1, #plys)]; Options.AimbotTarget:SetValue(targetPlayer.Name) else targetPlayer = nil end
            return
        end
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and string.find(string.lower(p.Name), name) then targetPlayer = p return end
        end
        targetPlayer = nil
    end
})

MiscGroupbox:AddButton({ Text = "🎯 Random Target", Func = function() Options.AimbotTarget:SetValue("ran") end })
MiscGroupbox:AddToggle("AimbotToggle", { Text = "Enable Aimbot (Look At)", Default = false })

-- ======================================================================
-- [ CORE LOOP: ESP & AIMBOT (FIXED FOR RESPAWN) ]
-- ======================================================================
RunService.RenderStepped:Connect(function()
    -- [ ESP SYSTEM ]
    if Toggles.PlayerESP and Toggles.PlayerESP.Value then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then
                local char = p.Character
                local head = char and char:FindFirstChild("Head")
                local hum = char and char:FindFirstChild("Humanoid")
                
                if char and head and hum and hum.Health > 0 then
                    -- 1. Fixed Highlight (Always reapplies on respawn)
                    local hl = char:FindFirstChild("ESPHighlight")
                    if not hl then
                        hl = Instance.new("Highlight")
                        hl.Name = "ESPHighlight"
                        hl.FillColor = Color3.new(1, 1, 1)
                        hl.OutlineColor = Color3.new(1, 1, 1)
                        hl.FillTransparency = 0.5
                        hl.OutlineTransparency = 0
                        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                        hl.Parent = char
                    end
                    hl.Adornee = char -- Re-confirm Adornee every frame

                    -- 2. Fixed BillboardGui (Name & Health re-attach)
                    local bb = espFolder:FindFirstChild(p.Name .. "_ESP")
                    if not bb then
                        bb = Instance.new("BillboardGui")
                        bb.Name = p.Name .. "_ESP"
                        bb.Size = UDim2.new(0, 100, 0, 40)
                        bb.AlwaysOnTop = true
                        bb.StudsOffset = Vector3.new(0, 3.5, 0)
                        bb.Parent = espFolder
                        
                        local lbl = Instance.new("TextLabel", bb)
                        lbl.Name = "Label"
                        lbl.Size = UDim2.new(1, 0, 1, 0)
                        lbl.BackgroundTransparency = 1
                        lbl.TextColor3 = Color3.new(1, 1, 1)
                        lbl.Font = Enum.Font.SourceSansBold
                        lbl.TextSize = 14
                    end
                    
                    -- Crucial: Re-attach Adornee to the current Head of the new Character
                    if bb.Adornee ~= head then
                        bb.Adornee = head
                    end

                    bb.Label.Text = p.Name .. "\n" .. math.floor(hum.Health) .. "/" .. math.floor(hum.MaxHealth)
                else
                    -- Cleanup old objects if player is dead or char is missing
                    local bb = espFolder:FindFirstChild(p.Name .. "_ESP")
                    if bb then bb.Adornee = nil bb.Label.Text = "" end
                end
            end
        end
    end

    -- [ AIMBOT SYSTEM ]
    if Toggles.AimbotToggle and Toggles.AimbotToggle.Value and targetPlayer then
        local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        local tRoot = targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        local tHum = targetPlayer.Character and targetPlayer.Character:FindFirstChild("Humanoid")
        if myRoot and tRoot and tHum and tHum.Health > 0 then
            myRoot.CFrame = CFrame.lookAt(myRoot.Position, Vector3.new(tRoot.Position.X, myRoot.Position.Y, tRoot.Position.Z))
        elseif tHum and tHum.Health <= 0 then
            Toggles.AimbotToggle:SetValue(false)
        end
    end
end)

